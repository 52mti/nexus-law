# 数据库配置
POSTGRES_USER=nexus_user
POSTGRES_PASSWORD=nexus_super_secret_password
POSTGRES_DB=nexus_law

# 2. Prisma 连接线 (注意这里的 @db:5432 是内网直连)
DATABASE_URL="postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/nexus_law?schema=public"

# 业务密钥
JWT_SECRET=your_production_jwt_secret_key_here
OPENAI_API_KEY=sk-xxxxxx...
OPENAI_BASE_URL=https://api.openai.com/v1